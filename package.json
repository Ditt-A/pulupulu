{
  "name": "pulupulu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:web dev:api",
    "dev:web": "vite",
    "dev:api": "node --env-file-if-exists=.env.local --watch server/index.mjs",
    "dev:full": "run-p dev:web dev:api",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "db:migrate": "node --env-file-if-exists=.env.local server/migrate.mjs",
    "seed": "node --env-file-if-exists=.env.local server/seed.mjs",
    "db:setup": "npm run db:migrate && npm run seed",
    "start": "node --env-file-if-exists=.env.local server/index.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@neondatabase/serverless": "^1.1.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
