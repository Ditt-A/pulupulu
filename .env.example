# PostgreSQL Neon connection string. Salin file ini menjadi .env.local.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Password awal hanya dibaca oleh seeder. Gunakan nilai baru yang belum pernah
# disimpan di Git; beri tanda kutip jika password memuat karakter #.
SEED_PASSWORD_FADILAH_MAULIDIYAH=
SEED_PASSWORD_DANIEL_MANALU=
SEED_PASSWORD_MAURA_RAMADHANI=
SEED_PASSWORD_YANCE_PANJAITAN=
SEED_PASSWORD_ZAKI_ALHILMI=
SEED_PASSWORD_SYAKILA_NAYLA=
SEED_PASSWORD_ADITYA_AKBAR=
SEED_PASSWORD_NIQUITA_ZAHARA=
SEED_PASSWORD_AKBAR_KUSUMA=
SEED_PASSWORD_IQBAL_FAIZIN=
SEED_PASSWORD_M_ADITYA_AKBAR=
SEED_PASSWORD_CHRISTAMA_EZRA=
SEED_PASSWORD_ALBERT_PASUNDA=
SEED_PASSWORD_ADMIN_MMD33=

# Server API lokal (opsional).
HOST=127.0.0.1
PORT=8787
